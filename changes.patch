+}
+
+.shop-container {
+  padding: 2rem;
+  min-height: 80vh;
+  background: var(--bg);
+}
+
+.shop-layout {
+  display: flex;
+  gap: 2rem;
+  align-items: flex-start;
+}
+
+.shop-sidebar {
+  width: 280px;
+  background: #fff;
+  padding: 24px;
+  border-radius: 12px;
+  box-shadow: 0 2px 12px rgba(0,0,0,0.08);
+}
+
+.shop-main {
+  flex: 1;
+}
+
+.filters h3 {
+  margin: 0 0 12px 0;
+  color: #1a1a1a;
+  font-weight: 600;
+  font-size: 16px;
+}
+
+.shop-sidebar section {
+  padding-bottom: 16px;
+  margin-bottom: 16px;
+  border-bottom: 1px solid #f0f0f0;
+}
+
+.category-list {
+  list-style: none;
+  padding: 0;
+  margin: 0 0 1rem 0;
+}
+
+.category-list li {
+  margin: 0.5rem 0;
+}
+
+.category-list label {
+  display: flex;
+  align-items: center;
+  gap: 0.5rem;
+}
+
+.category-list input[type='checkbox'] {
+  accent-color: var(--primary);
+}
+
+.category-list .count {
+  margin-left: auto;
+  color: var(--muted);
+}
+
+.price-range {
+  position: relative;
+  padding: 0.5rem 0 1rem 0;
+}
+
+.price-range input[type='range'] {
+  -webkit-appearance: none;
+  width: 100%;
+  background: transparent;
+  position: absolute;
+  left: 0;
+  height: 4px;
+}
+
+/* Track */
+.price-range input[type='range']::-webkit-slider-runnable-track {
+  height: 4px;
+  background: #e0e0e0;
+  border-radius: 4px;
+}
+.price-range input[type='range']::-moz-range-track {
+  height: 4px;
+  background: #e0e0e0;
+  border-radius: 4px;
+}
+
+/* Thumb */
+.price-range input[type='range']::-webkit-slider-thumb {
+  -webkit-appearance: none;
+  width: 18px;
+  height: 18px;
+  border-radius: 50%;
+  background: var(--primary);
+  margin-top: -7px;
+}
+.price-range input[type='range']::-moz-range-thumb {
+  width: 18px;
+  height: 18px;
+  border-radius: 50%;
+  background: var(--primary);
+  border: none;
+}
+
+.price-label {
+  margin-top: 2.5rem;
+  color: var(--muted);
+}
+
+.rating-group label {
+  display: block;
